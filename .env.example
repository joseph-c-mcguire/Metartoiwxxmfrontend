# Authentication Service Configuration
# The auth service acts as a middleware between frontend and Supabase
# No direct Supabase keys needed in frontend anymore!

# Auth Service URL (middleware proxy)
VITE_AUTH_SERVICE_URL=http://localhost:8002

# Frontend URLs
# These define where your frontend and backend services are running
VITE_APP_URL=http://localhost:8000
VITE_BACKEND_URL=http://localhost:8001

# ⚠️ IMPORTANT SETUP NOTES:
# 
# 1. Copy this file to .env:
#    cp frontend/.env.example frontend/.env
#
# 2. Update VITE_AUTH_SERVICE_URL if auth service is on a different port or host:
#    Default: http://localhost:8002 (local development)
#
# 3. Update VITE_APP_URL and VITE_BACKEND_URL to match your backend services:
#    Local development: http://localhost:8000 (frontend), http://localhost:8001 (backend)
#    Production: Update to match your deployed URLs
#
# 4. The auth service (port 8002) handles all Supabase authentication.
#    See docs/AUTH_MIDDLEWARE_ARCHITECTURE.md for details.
#
# 5. Restart your dev server after changing .env:
#    npm run dev
