# Supabase Configuration
# Get these values from Supabase Dashboard → Project Settings → API Keys

# The Supabase project URL (where your database and auth is hosted)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# The public anon key (SAFE to expose in frontend code)
# This key is used for client-side operations with Row Level Security (RLS)
# IMPORTANT: Use the NEW publishable key format if available (sb_publishable_xxx)
# For legacy projects, use the anon key from the Legacy API Keys tab
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-or-anon-key

# Optional: Supabase service role key (NEVER expose in frontend!)
# Only use this in backend/server code (.env files that don't get deployed to browser)
# VITE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Frontend URLs
VITE_APP_URL=http://localhost:8000
VITE_BACKEND_URL=http://localhost:8001
VITE_AUTH_URL=http://localhost:8002

# Note: For password reset and email verification flows,
# configure the Site URL in Supabase Dashboard → Authentication → URL Configuration
# This should match your frontend URL (e.g., http://localhost:5173 for dev)
